{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": ["APP_BASE_PATH"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "db:generate": {
      "outputs": ["prisma/generated/**"]
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "outputs": ["prisma/migrations/**"],
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
