# [platform] CVS-OS가 자동 주입. 로컬에서는 아래 기본값 사용
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ab-test-dashboard?schema=public
API_URL=http://api:3001
APP_BASE_PATH=

# [platform] CVS-OS가 개별 DB 변수로 주입 (로컬에서는 DATABASE_URL 사용)
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD

# Databricks (OAuth M2M)
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Slack
SLACK_USER_TOKEN=

# OpenAI (via AI Proxy 권장)
OPENAI_API_KEY=
OPENAI_RESTRICTION_MODEL=gpt-4o-mini

# Databricks SQL 뷰 이름
SERVING_CATALOG=analytics_serving
SERVING_SCHEMA=gameops
VIEW_AE_DAILY=ae_daily_secure
VIEW_AE_SEGMENT=ae_segment_secure
VIEW_AE_RETENTION=ae_retention_secure

# 기본값
DEFAULT_GAME_CODE=STARBLITZ
DEFAULT_REGION=ALL

# [optional]
LOG_LEVEL=info

# [optional] AI Proxy
# AIPROXY_BASE_URL=https://aiproxy-api.backoffice.bagelgames.com
# AIPROXY_TOKEN=aiproxy_xxxxxxxxxxxx
