PORT=3000
SENSOR_TOWER_API_TOKEN=

# Switch to "databricks" after you configure the service principal values below.
APP_MODE=mock

# Databricks workspace hostname only. Example: dbc-a1b2345c-d6e7.cloud.databricks.com
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=
DATABRICKS_SQL_WAREHOUSE_ID=
OPENAI_API_KEY=

# Slack User Token (xoxp-...) - search:read, channels:history, groups:history, files:read scope 필요
SLACK_USER_TOKEN=

# S3 Storage (설정 시 로컬 파일 대신 S3에 캐시/데이터 저장, CVS-OS 배포 시 자동 주입)
S3_BUCKET=
S3_REGION=ap-northeast-2
S3_PREFIX=
OPENAI_RESTRICTION_MODEL=gpt-5-mini

# Databricks object names used by the approved query registry.
SERVING_CATALOG=analytics_serving
SERVING_SCHEMA=gameops
VIEW_AE_DAILY=ae_daily_secure
VIEW_AE_SEGMENT=ae_segment_secure
VIEW_AE_RETENTION=ae_retention_secure

# Optional defaults surfaced in the UI.
DEFAULT_GAME_CODE=STARBLITZ
DEFAULT_REGION=ALL

# Local auth simulation. Turn REQUIRE_USER_IDENTITY=true behind your company proxy/SSO.
REQUIRE_USER_IDENTITY=false
TRUSTED_USER_EMAIL_HEADER=x-user-email
TRUSTED_USER_GROUPS_HEADER=x-user-groups
DEFAULT_USER_EMAIL=local.analyst@company.internal
DEFAULT_USER_GROUPS=analytics-secure,ae-readers,analytics-admin
GROUP_AE_READERS=ae-readers
GROUP_AE_RETENTION=ae-retention
GROUP_ANALYTICS_ADMIN=analytics-admin
